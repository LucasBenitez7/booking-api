        },
        {
          "name": "Unauthorized access (no token \u2014 expect 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/bookings",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookings"
              ]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Verifies that the endpoint rejects unauthenticated requests."
          },
          "event": [
            {
              "listen": "test",
