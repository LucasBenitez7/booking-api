# =============================================================================
# BookingAPI — environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false

# -----------------------------------------------------------------------------
# Database (required)
# Use postgresql+asyncpg:// driver for async SQLAlchemy.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://booking:booking@localhost:5432/booking_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Redis (optional — availability cache and Celery broker)
# If not set, the app falls back to an in-memory cache (not suitable for multi-process).
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Celery
# Broker and result backend should use separate Redis databases (e.g. /1 and /2)
# to avoid key collisions with the availability cache (/0).
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# How many hours before a booking start time the reminder task fires.
REMINDER_HOURS_BEFORE=24

# -----------------------------------------------------------------------------
# JWT — change both keys in production. Use secrets.token_hex(32) to generate.
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Set to true in production so the refresh token cookie is only sent over HTTPS.
REFRESH_TOKEN_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AUTH_PER_MINUTE=10

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
